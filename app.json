{
  "expo": {
    "name": "FitNEase",
    "slug": "fitnease-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/fitnease-og-logo.png",
    "scheme": "fitneaseclient",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "FitNEase needs camera access for video workouts with friends.",
        "NSMicrophoneUsageDescription": "FitNEase needs microphone access for video workouts with friends."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.fitnease.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/fitnease-og-logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE",
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "POST_NOTIFICATIONS"
      ]
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e82fecda-c86d-4d66-a9af-7aba6056f28f",
      "fallbackToCacheTimeout": 30000
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/fitnease-og-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FitNEase to access your camera for video workouts.",
          "microphonePermission": "Allow FitNEase to access your microphone for video workouts."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "-dontwarn com.google.devtools.build.android.desugar.runtime.ThrowableExtension\n-keep class io.agora.** { *; }\n-dontwarn io.agora.**"
          }
        }
      ],
      "./plugins/withAbiFilters",
      "./plugins/withRemoveMediaProjection",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#0284c7",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FitNEase to access your photos for your profile picture.",
          "cameraPermission": "Allow FitNEase to use your camera to take a profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e82fecda-c86d-4d66-a9af-7aba6056f28f"
      }
    },
    "owner": "gabsm2000"
  }
}
